<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Experiences - <%= settings.blogName %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <h2>Admin Panel</h2>
            <nav class="admin-nav">
                <a href="/admin/dashboard">Dashboard</a>
                <a href="/admin/articles">Articles</a>
                <a href="/admin/experiences" class="active">Experiences (CV)</a>
                <a href="/admin/settings">Settings</a>
                <a href="/admin/logout" style="margin-top: auto;">Logout</a>
            </nav>
        </aside>
        
        <main class="admin-main">
            <div class="admin-header">
                <h1>Manage Experiences / Education</h1>
            </div>
            
            <div class="admin-card">
                <h3>Add New Experience</h3>
                <form action="/admin/experiences" method="POST" style="margin-bottom: 30px;">
                    <div class="stat-grid" style="margin-bottom: var(--space-md);">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="title">Title / Degree (e.g. Sarjana Hukum)</label>
                            <input type="text" id="title" name="title" class="form-control" required>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="organization">Organization / University</label>
                            <input type="text" id="organization" name="organization" class="form-control" required>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="year">Year (e.g. 2020 - 2024)</label>
                            <input type="text" id="year" name="year" class="form-control" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="description">Description (Optional)</label>
                        <textarea id="description" name="description" class="form-control" rows="2"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Add Experience</button>
                </form>

                <hr style="margin: var(--space-lg) 0; border: none; border-top: 1px solid var(--border-color);">

                <h3>Current Experiences</h3>
                <% if (experiences.length > 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Organization</th>
                                <th>Year</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% experiences.forEach(exp => { %>
                                <tr>
                                    <td><strong><%= exp.title %></strong><br><small style="color:var(--text-secondary)"><%= exp.description %></small></td>
                                    <td><%= exp.organization %></td>
                                    <td><%= exp.year %></td>
                                    <td>
                                        <form action="/admin/experiences/delete/<%= exp.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this experience?');">
                                            <button type="submit" class="btn btn-danger" style="padding: 5px 10px; font-size: 12px;">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p style="color: #6b7280;">No experiences added yet.</p>
                <% } %>
            </div>
        </main>
    </div>
</body>
</html>
