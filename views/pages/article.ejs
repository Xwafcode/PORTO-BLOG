<%- include('../layouts/header', { title: article.title, description: article.excerpt }) %>

<article class="pt-12 pb-24 bg-neo-white min-h-screen">
    
    <!-- Header -->
    <header class="max-w-4xl mx-auto px-6 mb-12 text-center gsap-fade-up">
        <% if (article.category) { %>
            <div class="inline-block bg-neo-purple text-white px-6 py-2 rounded-full font-bold text-lg neo-border neo-shadow-sm mb-6 uppercase tracking-wider">
                <%= article.category %>
            </div>
        <% } %>
        
        <h1 class="font-heading font-black text-5xl md:text-7xl mb-8 leading-tight">
            <%= article.title %>
        </h1>
        
        <div class="flex flex-wrap items-center justify-center gap-4 md:gap-8 font-bold text-gray-600 bg-white neo-border px-8 py-4 rounded-xl neo-shadow-sm w-fit mx-auto">
            <span class="flex items-center gap-2">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <%= article.author || settings.authorName %>
            </span>
            <span class="hidden md:inline">•</span>
            <span class="flex items-center gap-2">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <%= new Date(article.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </span>
        </div>
    </header>

    <!-- Thumbnail -->
    <% if (article.thumbnail) { %>
        <div class="max-w-5xl mx-auto px-6 mb-16 gsap-fade-up">
            <div class="aspect-video w-full rounded-3xl neo-border border-[4px] neo-shadow-lg overflow-hidden relative">
                <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover">
                <!-- Retro overlay dots -->
                <div class="absolute inset-0 bg-dot opacity-20 pointer-events-none mix-blend-overlay"></div>
            </div>
        </div>
    <% } %>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-6">
        <% if (article.document && article.document.toLowerCase().endsWith('.pdf')) { %>
            <div class="mb-12 gsap-fade-up">
                <div class="bg-neo-black p-2 neo-border rounded-xl neo-shadow-lg mb-6">
                    <iframe src="<%= article.document %>#toolbar=0" class="w-full h-[600px] md:h-[800px] rounded-lg bg-white" frameborder="0" title="PDF Document"></iframe>
                </div>
            </div>
        <% } %>
        
        <% if (article.content && article.content.trim().length > 0 && article.content !== '<p><br></p>') { %>
            <div class="bg-white neo-border rounded-3xl p-8 md:p-12 neo-shadow-lg gsap-fade-up prose prose-lg md:prose-xl max-w-none prose-headings:font-heading prose-headings:font-black prose-a:text-neo-blue prose-a:font-bold prose-a:underline prose-img:rounded-xl prose-img:neo-border prose-img:neo-shadow-sm prose-blockquote:border-l-4 prose-blockquote:border-neo-yellow prose-blockquote:bg-yellow-50 prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:rounded-r-lg prose-pre:bg-gray-900 prose-pre:neo-border">
                <%- article.content %>
            </div>
        <% } %>
    </div>

    <!-- Footer / Tags / Share -->
    <footer class="max-w-3xl mx-auto px-6 mt-16 gsap-fade-up">
        <div class="bg-neo-yellow neo-border rounded-3xl p-8 md:p-12 neo-shadow-lg flex flex-col md:flex-row justify-between items-center gap-8">
            
            <!-- Tags -->
            <div class="flex-1">
                <h3 class="font-heading font-black text-2xl mb-4">TAGGED IN:</h3>
                <div class="flex flex-wrap gap-2">
                    <% if (article.tags && article.tags.length > 0) { %>
                        <% article.tags.forEach(tag => { %>
                            <span class="bg-white px-4 py-2 rounded-full font-bold text-sm neo-border neo-shadow-sm hover:-translate-y-1 transition-transform cursor-pointer">
                                #<%= tag %>
                            </span>
                        <% }) %>
                    <% } else { %>
                        <span class="font-medium">No tags.</span>
                    <% } %>
                </div>
            </div>
            
            <!-- Share -->
            <div class="md:text-right">
                <h3 class="font-heading font-black text-2xl mb-4">SHARE THIS:</h3>
                <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' - Baca selengkapnya di ' + 'http://localhost:3000/article/' + article.slug) %>" target="_blank" class="inline-flex items-center gap-2 bg-[#25d366] text-white px-6 py-3 rounded-xl font-bold neo-border neo-shadow hover:-translate-y-1 transition-transform">
                    <svg viewBox="0 0 32 32" width="24" height="24" fill="currentColor"><path d="M16 2a13 13 0 0 0-11 20l-2 5 5.5-1.5A13 13 0 1 0 16 2zm0 2.5A10.5 10.5 0 0 1 24.3 22.8l-1.8.8-1.7-2.6c-.2-.3-.5-.4-.8-.4-.3 0-.6.1-.9.3l-1.2 1.4c-2.3-1.1-4.2-3-5.3-5.3l1.4-1.2c.2-.3.3-.6.3-.9 0-.3-.1-.6-.4-.8l-2.6-1.7c-.1-.1-.3-.1-.4-.1s-.3 0-.4.1L9 16.2c-.3.4-.4 1-.2 1.6.6 2.3 2 4.4 3.9 6.3 1.9 1.9 4 3.3 6.3 3.9.6.2 1.2.1 1.6-.2l1.8-1.5c.2-.2.3-.5.1-.8l-2.6-1.7c-.1-.1-.3-.2-.5-.2z"/></svg>
                    WhatsApp
                </a>
            </div>
            
        </div>
    </footer>
    
</article>

<%- include('../layouts/footer') %>
