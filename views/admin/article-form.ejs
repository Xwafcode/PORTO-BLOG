<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= article ? 'Edit Article' : 'New Article' %> - <%= settings.blogName %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <h2>Admin Panel</h2>
            <nav class="admin-nav">
                <a href="/admin/dashboard">Dashboard</a>
                <a href="/admin/articles" class="active">Articles</a>
                <a href="/admin/experiences">Experiences (CV)</a>
                <a href="/admin/settings">Settings</a>
                <a href="/admin/logout" style="margin-top: auto;">Logout</a>
            </nav>
        </aside>
        
        <main class="admin-main">
            <div class="admin-header">
                <h1><%= article ? 'Edit Article' : 'Create New Article' %></h1>
                <a href="/admin/articles" class="btn" style="background: #e5e7eb;">Back to Articles</a>
            </div>
            
            <div class="admin-card">
                <form action="<%= article ? '/admin/articles/edit/' + article.id : '/admin/articles' %>" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input type="text" id="title" name="title" class="form-control" value="<%= article ? article.title : '' %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="excerpt">Excerpt (Short description)</label>
                        <textarea id="excerpt" name="excerpt" class="form-control" rows="3" required><%= article ? article.excerpt : '' %></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="thumbnail">Thumbnail Image</label>
                        <% if (article && article.thumbnail) { %>
                            <div style="margin-bottom: 10px;">
                                <img src="<%= article.thumbnail %>" alt="Current thumbnail" style="max-width: 200px; border-radius: 4px;">
                            </div>
                        <% } %>
                        <input type="file" id="thumbnail" name="thumbnail" class="form-control" accept="image/*">
                        <small style="color: #6b7280;">Leave empty to keep current image</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="document">Document File (PDF, DOC, DOCX)</label>
                        <% if (article && article.document) { %>
                            <div style="margin-bottom: 10px;">
                                <a href="<%= article.document %>" target="_blank" style="color: #4c93e6; font-weight: bold; text-decoration: underline;">View Current Document</a>
                            </div>
                        <% } %>
                        <input type="file" id="document" name="document" class="form-control" accept=".pdf,.doc,.docx">
                        <small style="color: #6b7280;">Upload a document to preserve formatting. Leave empty to keep current document.</small>
                    </div>
                    
                    <div class="stat-grid" style="margin-bottom: var(--space-md);">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="category">Category</label>
                            <input type="text" id="category" name="category" class="form-control" value="<%= article ? article.category : '' %>" placeholder="e.g. Technology">
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="status">Status</label>
                            <select id="status" name="status" class="form-control">
                                <option value="draft" <%= article && article.status === 'draft' ? 'selected' : '' %>>Draft</option>
                                <option value="published" <%= article && article.status === 'published' ? 'selected' : '' %>>Published</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="tags">Tags (comma separated)</label>
                        <input type="text" id="tags" name="tags" class="form-control" value="<%= article && article.tags ? article.tags.join(', ') : '' %>" placeholder="javascript, web dev, coding">
                    </div>
                    
                    <div class="form-group">
                        <label for="content">Content (HTML allowed)</label>
                        <textarea id="content" name="content" class="form-control" rows="15" required><%= article ? article.content : '' %></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Save Article</button>
                </form>
            </div>
        </main>
    </div>

    <script>
        document.getElementById('document').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            // Only extract .docx files
            if (file.name.endsWith('.docx')) {
                const contentArea = document.getElementById('content');
                const originalText = contentArea.value;
                contentArea.value = 'Extracting text from DOCX... Please wait.';
                
                const formData = new FormData();
                formData.append('document', file);
                
                try {
                    const response = await fetch('/admin/extract-docx', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    if (response.ok) {
                        contentArea.value = result.html;
                    } else {
                        alert('Error extracting document: ' + result.error);
                        contentArea.value = originalText;
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to extract document.');
                    contentArea.value = originalText;
                }
            }
        });
    </script>
</body>
</html>
