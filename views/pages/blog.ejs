<%- include('../layouts/header', { title: 'Blog & Tulisan' }) %>

<section class="bg-neo-blue py-20 neo-border-b border-b-[3px] border-neo-black relative overflow-hidden bg-dot">
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        <h1 class="font-heading font-black text-6xl md:text-8xl text-white drop-shadow-[4px_4px_0_rgba(18,18,18,1)] uppercase leading-none mb-6 gsap-fade-up">
            THE<br>
            <span class="text-neo-yellow">BLOG.</span>
        </h1>
        <p class="text-xl md:text-2xl font-medium text-white max-w-2xl mx-auto bg-neo-black px-6 py-2 rounded-full inline-block neo-shadow-sm gsap-fade-up" style="animation-delay: 0.1s;">
            Thoughts, tutorials, and legal notes.
        </p>
    </div>
    
    <!-- Decorative -->
    <div class="absolute top-10 left-10 bg-neo-pink neo-border p-4 rounded-xl neo-shadow transform -rotate-12 z-0">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="3"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
    </div>
</section>

<section class="py-24 bg-neo-white min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-6">
        
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6 gsap-fade-up">
            <h2 class="font-heading font-black text-4xl uppercase">All Articles</h2>
            
            <form action="/search" method="GET" class="flex w-full md:w-auto">
                <input type="text" name="q" placeholder="Search articles..." class="w-full md:w-64 bg-white neo-border border-r-0 rounded-l-xl px-4 py-3 font-medium focus:outline-none">
                <button type="submit" class="bg-neo-black text-white neo-border rounded-r-xl px-6 py-3 font-bold hover:bg-gray-800">
                    Search
                </button>
            </form>
        </div>

        <% if (articles && articles.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% articles.forEach((article, index) => { %>
                    <article class="bg-white neo-border rounded-2xl overflow-hidden neo-shadow hover:-translate-y-2 transition-transform flex flex-col h-full gsap-fade-up">
                        <% if (article.thumbnail) { %>
                            <div class="aspect-video neo-border-b border-b-[3px] border-neo-black relative overflow-hidden group">
                                <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                <% if (article.category) { %>
                                    <div class="absolute top-4 left-4 bg-neo-yellow neo-border px-3 py-1 rounded-full text-xs font-bold neo-shadow-sm uppercase">
                                        <%= article.category %>
                                    </div>
                                <% } %>
                            </div>
                        <% } else { %>
                            <div class="aspect-video bg-neo-purple neo-border-b border-b-[3px] border-neo-black relative flex items-center justify-center p-6 text-center">
                                <h3 class="font-heading font-black text-2xl text-white opacity-80"><%= article.title.substring(0, 30) %>...</h3>
                                <% if (article.category) { %>
                                    <div class="absolute top-4 left-4 bg-neo-yellow neo-border px-3 py-1 rounded-full text-xs font-bold neo-shadow-sm uppercase">
                                        <%= article.category %>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="text-sm font-bold text-gray-500 mb-3 uppercase tracking-wider flex items-center gap-2">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                <%= new Date(article.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </div>
                            
                            <h3 class="font-heading font-black text-2xl mb-3 leading-tight hover:text-neo-blue transition-colors">
                                <a href="/article/<%= article.slug %>"><%= article.title %></a>
                            </h3>
                            
                            <p class="font-medium text-gray-600 mb-6 flex-grow line-clamp-3">
                                <%= article.excerpt %>
                            </p>
                            
                            <div class="mt-auto">
                                <a href="/article/<%= article.slug %>" class="inline-flex items-center gap-2 bg-neo-black text-white px-5 py-2 rounded-lg font-bold hover:bg-gray-800 transition-colors neo-border neo-shadow-sm">
                                    Read More
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white neo-border rounded-2xl p-16 text-center neo-shadow max-w-2xl mx-auto">
                <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="2" class="mx-auto mb-6 text-gray-400"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                <h3 class="font-heading font-black text-3xl mb-4">No Articles Yet</h3>
                <p class="font-medium text-lg text-gray-600">Check back later for new content!</p>
            </div>
        <% } %>
    </div>
</section>

<%- include('../layouts/footer') %>
