<%- include('../layouts/header', { title: 'About' }) %>

<section class="bg-neo-pink py-20 neo-border-b border-b-[3px] border-neo-black relative overflow-hidden bg-grid">
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
        <h1 class="font-heading font-black text-6xl md:text-8xl text-neo-black drop-shadow-[4px_4px_0_rgba(255,255,255,1)] uppercase leading-none mb-6 gsap-fade-up">
            ABOUT<br>
            <span class="text-white drop-shadow-[4px_4px_0_rgba(18,18,18,1)]">ME.</span>
        </h1>
        <p class="text-xl md:text-2xl font-medium text-neo-black max-w-2xl mx-auto bg-white px-6 py-2 rounded-full inline-block neo-shadow-sm neo-border gsap-fade-up" style="animation-delay: 0.1s;">
            The story behind the screen.
        </p>
    </div>
</section>

<section class="py-24 bg-neo-white">
    <div class="max-w-4xl mx-auto px-6">
        <div class="bg-white neo-border rounded-3xl p-8 md:p-12 neo-shadow-lg relative gsap-fade-up">
            
            <div class="flex flex-col md:flex-row gap-12 items-center mb-12">
                <div class="w-48 h-48 rounded-full neo-border neo-shadow-sm overflow-hidden flex-shrink-0 relative bg-neo-yellow">
                    <% if (settings.authorPhoto) { %>
                        <img src="<%= settings.authorPhoto %>" alt="<%= settings.authorName %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center font-heading font-black text-6xl">
                            <%= settings.authorName.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <!-- decorative badge -->
                    <div class="absolute bottom-2 right-2 bg-neo-purple text-white w-12 h-12 rounded-full neo-border flex items-center justify-center font-bold text-xl">
                        ★
                    </div>
                </div>
                
                <div>
                    <h2 class="font-heading font-black text-4xl mb-2"><%= settings.authorName %></h2>
                    <h3 class="font-bold text-xl text-neo-blue mb-6"><%= settings.tagline %></h3>
                    <p class="font-medium text-lg text-gray-700 leading-relaxed">
                        <%= settings.description %>
                    </p>
                </div>
            </div>

            <hr class="border-2 border-neo-black mb-12">
            
            <div class="text-center bg-neo-yellow neo-border rounded-2xl p-8 neo-shadow-sm transform rotate-1 hover:rotate-0 transition-transform">
                <h3 class="font-heading font-black text-3xl mb-4">Let's collaborate!</h3>
                <p class="font-medium text-lg mb-6 max-w-lg mx-auto">
                    I'm always open to discussing product design work or partnership opportunities.
                </p>
                <a href="https://wa.me/<%= settings.whatsappNumber %>?text=<%= encodeURIComponent('Halo ' + settings.authorName + ', saya ingin berdiskusi.') %>" target="_blank" class="inline-flex items-center gap-3 bg-neo-black text-white px-8 py-4 rounded-xl font-bold text-lg neo-shadow-sm hover:bg-gray-800 transition-colors">
                    <svg viewBox="0 0 32 32" width="24" height="24" fill="currentColor"><path d="M16 2a13 13 0 0 0-11 20l-2 5 5.5-1.5A13 13 0 1 0 16 2zm0 2.5A10.5 10.5 0 0 1 24.3 22.8l-1.8.8-1.7-2.6c-.2-.3-.5-.4-.8-.4-.3 0-.6.1-.9.3l-1.2 1.4c-2.3-1.1-4.2-3-5.3-5.3l1.4-1.2c.2-.3.3-.6.3-.9 0-.3-.1-.6-.4-.8l-2.6-1.7c-.1-.1-.3-.1-.4-.1s-.3 0-.4.1L9 16.2c-.3.4-.4 1-.2 1.6.6 2.3 2 4.4 3.9 6.3 1.9 1.9 4 3.3 6.3 3.9.6.2 1.2.1 1.6-.2l1.8-1.5c.2-.2.3-.5.1-.8l-2.6-1.7c-.1-.1-.3-.2-.5-.2z"/></svg>
                    Chat on WhatsApp
                </a>
            </div>

        </div>
    </div>
</section>

<%- include('../layouts/footer') %>
