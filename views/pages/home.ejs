<%- include('../layouts/header', { title: 'Home' }) %>

<section class="max-w-7xl mx-auto px-6 py-12 lg:py-24">
    <div class="bg-neo-white rounded-3xl p-8 lg:p-16 relative overflow-hidden">
        <div class="inline-block bg-neo-blue text-white font-bold px-6 py-2 rounded-full neo-border neo-shadow-sm mb-8 transform -rotate-2">
            &#128075; Hello, I am <%= settings.authorName.split(' ')[0] %>
        </div>
        
        <div class="flex flex-col lg:flex-row gap-12 items-center justify-between">
            <div class="lg:w-3/5 z-10 relative">
                <div class="overflow-hidden mb-2">
                    <div id="hero-line-1" class="font-heading font-black text-6xl md:text-8xl lg:text-[100px] leading-[0.9] uppercase tracking-tight opacity-0" style="transform: translateY(130px) rotate(10deg);">
                        I WRITE
                    </div>
                </div>
                <div class="overflow-hidden mb-2">
                    <div id="hero-line-2" class="font-heading font-black text-6xl md:text-8xl lg:text-[100px] leading-[0.9] uppercase tracking-tight opacity-0" style="transform: translateY(130px) rotate(10deg);">
                        <span class="text-transparent" style="-webkit-text-stroke: 3px #121212;">COOL</span>
                    </div>
                </div>
                <div class="overflow-hidden mb-8">
                    <div id="hero-line-3" class="font-heading font-black text-6xl md:text-8xl lg:text-[100px] leading-[0.9] uppercase tracking-tight opacity-0" style="transform: translateY(130px) rotate(10deg);">
                        STUFF.
                    </div>
                </div>
                
                <div class="bg-white neo-border rounded-xl p-6 lg:p-8 neo-shadow max-w-xl">
                    <p class="font-medium text-lg lg:text-xl text-gray-800">
                        A Law student at University of Mataram with a deep passion for legal writing and debate. I write to understand, and debate to argue.
                    </p>
                </div>
                
                <div class="flex flex-wrap gap-4 mt-8">
                    <a href="/blog" class="bg-neo-red text-white neo-border px-8 py-4 rounded-xl font-bold text-lg neo-shadow hover:bg-red-500 flex items-center gap-2">
                        Read My Publications
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                    </a>
                </div>
            </div>
            
            <div class="lg:w-2/5 relative flex justify-center mt-12 lg:mt-0">
                <div id="deco-scale" class="absolute -top-10 -left-10 bg-white neo-border p-3 rounded-lg neo-shadow z-20" style="transform: rotate(-12deg) scale(0); transform-origin: center;">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#9b6cff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/>
                        <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/>
                        <path d="M7 21h10"/>
                        <path d="M12 3v18"/>
                        <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>
                    </svg>
                </div>
                <div id="deco-bolt" class="absolute bottom-10 -right-10 bg-neo-yellow neo-border p-4 rounded-xl neo-shadow z-20" style="transform: rotate(12deg) scale(0); transform-origin: center;">
                    <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="3"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                </div>
                <div id="deco-writing" class="absolute bottom-20 -left-5 bg-white neo-border px-4 py-2 rounded-full neo-shadow z-20 font-bold" style="transform: rotate(-6deg) scale(0); transform-origin: center;">
                    WRITING
                </div>
                
                <div id="hero-avatar" class="relative w-72 h-72 lg:w-96 lg:h-96 flex items-center justify-center" style="transform: scale(0.2); opacity: 0;">
                    <img src="/images/hero.png" alt="Hero Image" class="w-full h-full object-contain z-10">
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Text lines slide up with steep tilt, staggered — finishes ~1.35s
    ['#hero-line-1', '#hero-line-2', '#hero-line-3'].forEach((el, i) => {
        gsap.to(el, {
            opacity: 1, y: 0, rotate: 0,
            duration: 0.85, ease: 'power3.out',
            delay: 0.2 + i * 0.15
        });
    });

    // Avatar pops AFTER text finishes
    gsap.to('#hero-avatar', {
        opacity: 1, scale: 1,
        duration: 0.8, ease: 'back.out(1.8)',
        delay: 1.35
    });

    // Icons pop simultaneously — scale only, no fade
    ['#deco-scale', '#deco-bolt', '#deco-writing'].forEach(id => {
        gsap.to(id, {
            scale: 1,
            duration: 0.6, ease: 'back.out(2.5)',
            delay: 1.4
        });
    });

    // Floating loops on icons
    gsap.to('#deco-scale',   { y: -10, rotation: '-=6', duration: 2.2, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 2.1 });
    gsap.to('#deco-bolt',    { y: -12, rotation: '+=7', duration: 2.7, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 2.3 });
    gsap.to('#deco-writing', { y:  -7, rotation: '-=4', duration: 1.9, repeat: -1, yoyo: true, ease: 'sine.inOut', delay: 2.5 });
</script>

<!-- Marquee -->
<div id="marquee-bar" class="bg-neo-black text-neo-yellow py-4 flex overflow-hidden border-b-[3px] border-neo-black">
    <div class="whitespace-nowrap font-heading font-bold text-2xl uppercase tracking-widest flex items-center animate-[marquee_20s_linear_infinite]">
        <span class="mx-4">&bull;</span> CIVIL LAW
        <span class="mx-4">&bull;</span> CRIMINAL LAW
        <span class="mx-4">&bull;</span> CONSTITUTIONAL LAW
        <span class="mx-4">&bull;</span> LEGAL RESEARCH
        <span class="mx-4">&bull;</span> HUMAN RIGHTS
        <span class="mx-4 text-neo-purple">&bull;</span> JURISPRUDENCE
        <span class="mx-4">&bull;</span> CORPORATE LAW
        <span class="mx-4">&bull;</span> CONTRACT DRAFTING
        <span class="mx-4">&bull;</span> CIVIL LAW
        <span class="mx-4">&bull;</span> CRIMINAL LAW
        <span class="mx-4">&bull;</span> CONSTITUTIONAL LAW
        <span class="mx-4">&bull;</span> LEGAL RESEARCH
        <span class="mx-4">&bull;</span> HUMAN RIGHTS
        <span class="mx-4 text-neo-purple">&bull;</span> JURISPRUDENCE
    </div>
</div>

<style>
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
</style>

<!-- Selected Works (Articles/Blog) -->
<section class="bg-neo-yellow py-24 neo-border-b border-b-[3px] border-neo-black bg-dot">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-16">
            <div class="selected-works-header">
                <h2 class="font-heading font-black text-6xl md:text-8xl text-white drop-shadow-[4px_4px_0_rgba(18,18,18,1)] uppercase leading-none">
                    SELECTED<br>WORKS.
                </h2>
                <div class="mt-4 inline-block font-bold text-xl border-b-4 border-neo-black pb-1">
                    Stuff I'm proud of.
                </div>
            </div>
            <div class="hidden md:block selected-works-icon">
                <svg viewBox="0 0 24 24" width="60" height="60" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
            </div>
        </div>

        <% if (articles && articles.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                <% articles.slice(0, 6).forEach((article, index) => { %>
                    <% const tilt = index % 2 === 0 ? '-rotate-[2.5deg]' : 'rotate-[2.5deg]'; %>
                    <div class="article-card">
                        <a href="/article/<%= article.slug %>" class="block group">
                            <div class="bg-white border-[3px] border-neo-black rounded-2xl overflow-hidden <%= tilt %> transition-transform duration-300 group-hover:rotate-0 group-hover:-translate-y-2" style="box-shadow: 7px 7px 0px #121212;">
                                <div class="p-4 pb-0">
                                    <div class="w-full rounded-xl overflow-hidden bg-gray-100" style="aspect-ratio: 16/9;">
                                        <% if (article.thumbnail) { %>
                                            <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                        <% } else { %>
                                            <div class="w-full h-full bg-neo-blue flex items-center justify-center">
                                                <span class="text-white font-heading font-black text-xl opacity-50 text-center px-4"><%= article.title.substring(0, 20) %>...</span>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="p-6">
                                    <% if (article.category) { %>
                                        <span class="inline-block bg-neo-purple text-white px-3 py-1 rounded-full font-bold text-xs border-[2px] border-neo-black mb-3"><%= article.category %></span>
                                    <% } %>
                                    <h3 class="font-heading font-black text-xl mb-2 uppercase leading-tight"><%= article.title %></h3>
                                    <p class="text-sm font-medium text-gray-600 leading-relaxed line-clamp-2"><%= article.excerpt %></p>
                                    <div class="mt-4 text-xs font-bold text-gray-400 uppercase tracking-wider">
                                        <%= new Date(article.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' }) %>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
            <div class="mt-16 text-center view-all-btn">
                <a href="/blog" class="inline-block bg-white neo-border px-10 py-4 rounded-xl font-bold text-xl neo-shadow hover:-translate-y-1 transition-transform">
                    View All Articles
                </a>
            </div>
        <% } else { %>
            <div class="bg-white neo-border rounded-xl p-12 text-center neo-shadow">
                <h3 class="font-heading font-black text-3xl mb-4">Coming Soon</h3>
                <p class="font-medium text-lg">No articles published yet.</p>
            </div>
        <% } %>
    </div>
</section>

<!-- Experience Section -->
<section class="bg-neo-purple py-24 neo-border-b border-b-[3px] border-neo-black relative overflow-hidden bg-grid">
    <div class="max-w-4xl mx-auto px-6 relative z-10">
        <h2 class="scroll-reveal font-heading font-black text-5xl md:text-7xl text-white text-center mb-16 drop-shadow-[4px_4px_0_rgba(18,18,18,1)] uppercase">EXPERIENCE</h2>
        
        <% if (experiences && experiences.length > 0) { %>
            <div class="relative border-l-4 border-neo-black ml-4 md:ml-8 pl-8 md:pl-12 space-y-12">
                <% experiences.forEach((exp, index) => { %>
                    <div class="relative scroll-reveal-left">
                        <div class="absolute -left-[45px] md:-left-[61px] top-4 w-6 h-6 rounded-full border-4 border-neo-black <%= index % 2 === 0 ? 'bg-neo-yellow' : 'bg-[#4ade80]' %> z-10"></div>
                        <div class="bg-white neo-border rounded-xl p-8 neo-shadow-lg hover:-translate-y-2 transition-transform">
                            <div class="inline-block bg-neo-black text-white px-4 py-1 rounded-full font-bold text-sm mb-4"><%= exp.year %></div>
                            <h3 class="font-heading font-bold text-3xl mb-1"><%= exp.title %></h3>
                            <h4 class="font-bold text-xl text-neo-pink mb-4"><%= exp.organization %></h4>
                            <p class="font-medium text-gray-700 leading-relaxed"><%= exp.description %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white neo-border rounded-xl p-12 text-center neo-shadow">
                <p class="font-medium text-lg">Data pengalaman belum ditambahkan.</p>
            </div>
        <% } %>
    </div>
</section>

