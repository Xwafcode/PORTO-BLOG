<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - <%= settings.blogName %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <h2>Admin Panel</h2>
            <nav class="admin-nav">
                <a href="/admin/dashboard" class="active">Dashboard</a>
                <a href="/admin/articles">Articles</a>
                <a href="/admin/experiences">Experiences (CV)</a>
                <a href="/admin/settings">Settings</a>
                <a href="/admin/logout" style="margin-top: auto;">Logout</a>
            </nav>
        </aside>
        
        <main class="admin-main">
            <div class="admin-header">
                <h1>Dashboard</h1>
                <a href="/" target="_blank" class="btn btn-primary">View Site</a>
            </div>
            
            <div class="stat-grid">
                <div class="stat-card">
                    <h3><%= totalArticles %></h3>
                    <p>Total Articles</p>
                </div>
                <div class="stat-card">
                    <h3><%= totalCategories %></h3>
                    <p>Total Categories</p>
                </div>
            </div>
            
            <div class="admin-card" style="margin-top: 30px;">
                <h2>Recent Articles</h2>
                <% if (recentArticles.length > 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentArticles.forEach(article => { %>
                                <tr>
                                    <td><%= article.title %></td>
                                    <td><%= new Date(article.createdAt).toLocaleDateString() %></td>
                                    <td><%= article.status %></td>
                                    <td>
                                        <a href="/admin/articles/edit/<%= article.id %>" class="btn" style="padding: 5px 10px; font-size: 12px; background: #e5e7eb;">Edit</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p>No articles yet.</p>
                <% } %>
            </div>
        </main>
    </div>
</body>
</html>
